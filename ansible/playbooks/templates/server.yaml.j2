---
# MXCubeWeb server configuration
# Generated by Ansible — do not edit manually on the server.
# To change settings, update group_vars/all.yml (or host_vars/<host>.yml)
# and re-run the deploy playbook with tag: config

server:
  HOST: "{{ mxcubeweb_config.host }}"
  PORT: {{ mxcubeweb_config.port }}
  DEBUG: {{ mxcubeweb_config.debug | lower }}

  # Secrets — store these in ansible-vault in production
  SECRET_KEY: "{{ mxcubeweb_config.secret_key }}"
  SECURITY_PASSWORD_SALT: "{{ mxcubeweb_config.security_password_salt }}"

  PERMANENT_SESSION_LIFETIME: {{ mxcubeweb_config.permanent_session_lifetime }}
  USER_DB_PATH: "{{ mxcubeweb_config.user_db_path }}"

  # SSL: NONE | ADHOC | SIGNED
  CERT: "{{ mxcubeweb_config.cert }}"
{% if mxcubeweb_config.cert == "SIGNED" %}
  CERT_PEM: "{{ mxcubeweb_config.cert_pem }}"
  CERT_KEY: "{{ mxcubeweb_config.cert_key }}"
{% endif %}

  ALLOWED_CORS_ORIGINS:
{% for origin in mxcubeweb_config.allowed_cors_origins %}
    - "{{ origin }}"
{% endfor %}
  RATELIMIT_DEFAULT: "150000 per day;6000 per hour"

sso:
  USE_SSO: {{ mxcubeweb_sso.use_sso | lower }}
  ISSUER: "{{ mxcubeweb_sso.issuer }}"
  LOGOUT_URI: "{{ mxcubeweb_sso.logout_uri }}"
  TOKEN_INFO_URI: "{{ mxcubeweb_sso.token_info_uri }}"
  META_DATA_URI: "{{ mxcubeweb_sso.meta_data_uri }}"
  CLIENT_ID: "{{ mxcubeweb_sso.client_id }}"
  CLIENT_SECRET: "{{ mxcubeweb_sso.client_secret }}"
  SCOPE: "{{ mxcubeweb_sso.scope }}"
  CODE_CHALLANGE_METHOD: "{{ mxcubeweb_sso.code_challenge_method }}"

mxcube:
  USE_EXTERNAL_STREAMER: {{ mxcubeweb_video.use_external_streamer | lower }}
  VIDEO_FORMAT: "{{ mxcubeweb_video.format }}"
  VIDEO_STREAM_URL: "{{ mxcubeweb_video.stream_url }}"
  VIDEO_STREAM_PORT: {{ mxcubeweb_video.stream_port }}
  MXCUBE_STARTS_VIDEO_STREAM: {{ mxcubeweb_video.mxcube_starts_stream | lower }}
  mode: OSC
  SESSION_REFRESH_INTERVAL: 9000
  USE_GET_SAMPLES_FROM_SC: true
  AUTOSYNC_LIMS: false

  usermanager:
    class: UserManager
    inhouse_is_staff: true
    users:
{% for user in mxcubeweb_users %}
      - username: "{{ user.username }}"
        role: "{{ user.role }}"
{% endfor %}

argus:
  USE_ARGUS: {{ mxcubeweb_argus.enabled | lower }}
  STREAM_PROXY_URL: "{{ mxcubeweb_argus.stream_proxy_url }}"

braggy:
  BRAGGY_URL: "{{ mxcubeweb_braggy.url }}"
  USE_BRAGGY: {{ mxcubeweb_braggy.enabled | lower }}
