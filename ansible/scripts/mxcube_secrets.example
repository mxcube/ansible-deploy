# MXCuBE deployment secrets template
# Copy this file to ~/.mxcube_secrets, fill in the values, then:
#   source ~/.mxcube_secrets
#
# Generate SECRET_KEY and SECURITY_PASSWORD_SALT with:
#   python -c 'import secrets; print(secrets.token_hex())'
#
# MXCUBE_SSO_CLIENT_SECRET: get this from the Keycloak admin console.

export MXCUBE_SECRET_KEY=""
export MXCUBE_SECURITY_PASSWORD_SALT=""
export MXCUBE_SSO_CLIENT_SECRET=""
